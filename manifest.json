{
  "manifest_version": 3,
  "name": "Stealth Focus",
  "version": "1.0.0",
  "description": "Spy-themed focus extension that redirects distracting tabs.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stealth Focus"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"]
}