{
  "manifest_version": 3,
  "name": "Stealth Focus",
  "version": "1.0.0",
  "description": "Spy-themed focus extension that redirects distracting tabs.",
  "icons": {
    "16": "assets/stealth_icon_16.png",
    "32": "assets/stealth_icon_32.png",
    "48": "assets/stealth_icon_48.png",
    "128": "assets/stealth_icon_128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stealth Focus",
    "default_icon": "assets/stealth_icon_16.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"]
}